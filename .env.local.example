# ===== LLM =====
OPENROUTER_API_KEY=
# Embeddings only — OpenRouter exposes no embedding models, so this is required.
OPENAI_API_KEY=

# ===== Supabase =====
SUPABASE_URL=
# Server-only. NEVER prefix with NEXT_PUBLIC_ — no client-side DB access.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Auth (Auth.js v5, Google, single-user allowlist) =====
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# The ONE email allowed to sign in.
ALLOWED_EMAIL=

# ===== Observability =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Layer 3 (web fallback) — not used in Layer 1 =====
TAVILY_API_KEY=

# ===== Pipeline =====
# Shared secret for internal self-retrigger calls between pipeline steps.
CRON_SECRET=
# Hard stop per run. Orchestrator fails the run with `budget_exceeded` above this.
RUN_BUDGET_USD=1.5
